// IOC Pivot: Suspicious IP 185.234.219.47
// Correlates network connections, alerts, and user accounts across MDE tables
let suspiciousIP = "185.234.219.47";
let lookback = 30d;

// --- 1. Devices that made network connections to the IP ---
let networkHits = materialize(
    DeviceNetworkEvents
    | where Timestamp > ago(lookback)
    | where RemoteIP == suspiciousIP
    | project
        Timestamp,
        DeviceId,
        DeviceName,
        LocalIP,
        RemoteIP,
        RemotePort,
        RemoteUrl,
        Protocol,
        ActionType,
        AccountName        = InitiatingProcessAccountName,
        AccountDomain      = InitiatingProcessAccountDomain,
        AccountUpn         = InitiatingProcessAccountUpn,
        ProcessName        = InitiatingProcessFileName,
        ProcessCommandLine = InitiatingProcessCommandLine,
        ParentProcess      = InitiatingProcessParentFileName,
        Source             = "DeviceNetworkEvents"
);

// --- 2. Files downloaded directly from the IP ---
let fileHits = materialize(
    DeviceFileEvents
    | where Timestamp > ago(lookback)
    | where FileOriginIP == suspiciousIP
    | project
        Timestamp,
        DeviceId,
        DeviceName,
        LocalIP            = "",
        RemoteIP           = FileOriginIP,
        RemotePort         = int(null),
        RemoteUrl          = FileOriginUrl,
        Protocol           = "",
        ActionType,
        AccountName        = InitiatingProcessAccountName,
        AccountDomain      = InitiatingProcessAccountDomain,
        AccountUpn         = InitiatingProcessAccountUpn,
        ProcessName        = InitiatingProcessFileName,
        ProcessCommandLine = InitiatingProcessCommandLine,
        ParentProcess      = InitiatingProcessParentFileName,
        Source             = "DeviceFileEvents"
);

// --- 3. Alerts directly referencing the IP ---
let alertHits = materialize(
    AlertEvidence
    | where Timestamp > ago(lookback)
    | where RemoteIP == suspiciousIP or LocalIP == suspiciousIP
    | join kind=inner (
        AlertInfo
        | project AlertId, AlertTitle = Title, Severity, Category,
                  ServiceSource, DetectionSource, AttackTechniques
    ) on AlertId
    | project
        Timestamp,
        AlertId,
        AlertTitle,
        Severity,
        Category,
        ServiceSource,
        DetectionSource,
        AttackTechniques,
        DeviceId,
        DeviceName,
        AccountName,
        AccountDomain,
        AccountUpn,
        RemoteIP,
        EntityType,
        EvidenceRole
);

// --- 4. Devices implicated in alerts (expand alert scope) ---
let alertedDeviceIds = alertHits | distinct DeviceId | where isnotempty(DeviceId);

// --- 5. Collect all unique device IDs touched by the IP ---
let allDeviceIds = materialize(
    union
        (networkHits | distinct DeviceId),
        (fileHits    | distinct DeviceId),
        (alertedDeviceIds)
    | distinct DeviceId
    | where isnotempty(DeviceId)
);

// --- 6. Enrich device metadata ---
let deviceMeta = materialize(
    DeviceInfo
    | where Timestamp > ago(lookback)
    | where DeviceId in (allDeviceIds)
    | summarize arg_max(Timestamp, *) by DeviceId
    | project DeviceId, DeviceName, OSPlatform, OSVersion,
              IsInternetFacing, ExposureLevel, MachineGroup
);

// --- 7. Collect all unique account names from raw hits ---
let involvedAccounts = materialize(
    union
        (networkHits | where isnotempty(AccountName) | project AccountName, AccountDomain, AccountUpn),
        (fileHits    | where isnotempty(AccountName) | project AccountName, AccountDomain, AccountUpn),
        (alertHits   | where isnotempty(AccountName) | project AccountName, AccountDomain, AccountUpn)
    | distinct AccountName, AccountDomain, AccountUpn
);

// --- 8. Enrich account identity from IdentityInfo ---
let identityMeta = materialize(
    IdentityInfo
    | where AccountName in (involvedAccounts | project AccountName)
    | project AccountName, AccountUpn, AccountObjectId,
              AccountDisplayName, Department, JobTitle,
              IsAccountEnabled, EmailAddress
    | summarize arg_max(AccountObjectId, *) by AccountName
);

// =====================================================================
// FINAL CORRELATED RESULT SET
// Rows 1-N: one row per raw connection / file download event
// =====================================================================
union
// Network connection rows
(
    networkHits
    | join kind=leftouter deviceMeta   on DeviceId
    | join kind=leftouter identityMeta on AccountName
    | extend
        AlertId          = "",
        AlertTitle       = "",
        Severity         = "",
        Category         = "",
        AttackTechniques = "",
        FileName         = "",
        FileOriginUrl    = ""
    | project
        Timestamp,
        Source,
        // Device
        DeviceId,
        DeviceName       = DeviceName1,
        OSPlatform,
        OSVersion,
        IsInternetFacing,
        ExposureLevel,
        MachineGroup,
        // Network
        LocalIP,
        RemoteIP,
        RemotePort,
        RemoteUrl,
        Protocol,
        ActionType,
        // Process
        ProcessName,
        ProcessCommandLine,
        ParentProcess,
        // Account
        AccountName,
        AccountDomain,
        AccountUpn,
        AccountDisplayName,
        AccountObjectId,
        Department,
        JobTitle,
        IsAccountEnabled,
        // Alert
        AlertId,
        AlertTitle,
        Severity,
        Category,
        AttackTechniques
),
// File download rows
(
    fileHits
    | join kind=leftouter deviceMeta   on DeviceId
    | join kind=leftouter identityMeta on AccountName
    | extend
        AlertId          = "",
        AlertTitle       = "",
        Severity         = "",
        Category         = "",
        AttackTechniques = ""
    | project
        Timestamp,
        Source,
        DeviceId,
        DeviceName       = DeviceName1,
        OSPlatform,
        OSVersion,
        IsInternetFacing,
        ExposureLevel,
        MachineGroup,
        LocalIP,
        RemoteIP,
        RemotePort,
        RemoteUrl,
        Protocol,
        ActionType,
        ProcessName,
        ProcessCommandLine,
        ParentProcess,
        AccountName,
        AccountDomain,
        AccountUpn,
        AccountDisplayName,
        AccountObjectId,
        Department,
        JobTitle,
        IsAccountEnabled,
        AlertId,
        AlertTitle,
        Severity,
        Category,
        AttackTechniques
),
// Alert rows
(
    alertHits
    | join kind=leftouter deviceMeta   on DeviceId
    | join kind=leftouter identityMeta on AccountName
    | extend
        LocalIP           = "",
        RemotePort        = int(null),
        RemoteUrl         = "",
        Protocol          = "",
        ProcessName       = "",
        ProcessCommandLine = "",
        ParentProcess     = ""
    | project
        Timestamp,
        Source           = "AlertEvidence",
        DeviceId,
        DeviceName       = DeviceName1,
        OSPlatform,
        OSVersion,
        IsInternetFacing,
        ExposureLevel,
        MachineGroup,
        LocalIP,
        RemoteIP,
        RemotePort,
        RemoteUrl,
        Protocol,
        ActionType       = EntityType,
        ProcessName,
        ProcessCommandLine,
        ParentProcess,
        AccountName,
        AccountDomain,
        AccountUpn,
        AccountDisplayName,
        AccountObjectId,
        Department,
        JobTitle,
        IsAccountEnabled,
        AlertId,
        AlertTitle,
        Severity,
        Category,
        AttackTechniques
)
| order by Timestamp desc
