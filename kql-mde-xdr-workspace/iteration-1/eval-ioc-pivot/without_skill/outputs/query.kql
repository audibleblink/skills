// IOC Pivot Query: Suspicious IP 185.234.219.47
// Correlates network connections, alerts, and user accounts across MDE/M365D tables

let SuspiciousIP = "185.234.219.47";

// 1. Network connections to the suspicious IP (DeviceNetworkEvents)
let NetworkHits = DeviceNetworkEvents
| where RemoteIP == SuspiciousIP
| project
    Timestamp,
    DeviceId,
    DeviceName,
    InitiatingProcessAccountName,
    InitiatingProcessAccountDomain,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    LocalIP,
    LocalPort,
    RemoteIP,
    RemotePort,
    Protocol,
    ActionType,
    ReportId
| extend Source = "DeviceNetworkEvents";

// 2. DNS queries resolving to the suspicious IP
let DnsHits = DeviceNetworkEvents
| where RemoteIP == SuspiciousIP
| where ActionType == "DnsQueryResponse" or isnotempty(RemoteUrl)
| project
    Timestamp,
    DeviceId,
    DeviceName,
    InitiatingProcessAccountName,
    InitiatingProcessAccountDomain,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    LocalIP,
    LocalPort,
    RemoteIP,
    RemotePort,
    Protocol,
    ActionType,
    ReportId
| extend Source = "DeviceNetworkEvents_DNS";

// 3. Alerts linked to the suspicious IP
let AlertHits = AlertEvidence
| where RemoteIP == SuspiciousIP or EntityType == "Ip" and EvidenceRole != ""
| join kind=leftouter (
    AlertInfo
    | project AlertId, Title, Severity, Category, AttackTechniques, ServiceSource, DetectionSource
) on AlertId
| project
    Timestamp,
    AlertId,
    Title,
    Severity,
    Category,
    AttackTechniques,
    ServiceSource,
    DetectionSource,
    DeviceId,
    DeviceName,
    AccountName,
    AccountDomain,
    EvidenceRole,
    RemoteIP,
    EntityType
| extend Source = "AlertEvidence";

// 4. All unique devices that touched the IP
let AffectedDevices = NetworkHits
| summarize
    FirstSeen = min(Timestamp),
    LastSeen = max(Timestamp),
    ConnectionCount = count(),
    Processes = make_set(InitiatingProcessFileName, 20),
    LocalIPs = make_set(LocalIP, 10),
    RemotePorts = make_set(RemotePort, 10)
    by DeviceId, DeviceName;

// 5. All unique user accounts involved via network activity
let AffectedUsers = NetworkHits
| where isnotempty(InitiatingProcessAccountName)
| summarize
    FirstSeen = min(Timestamp),
    LastSeen = max(Timestamp),
    ConnectionCount = count(),
    DevicesUsed = make_set(DeviceName, 20)
    by
    AccountName = InitiatingProcessAccountName,
    AccountDomain = InitiatingProcessAccountDomain;

// 6. Check IdentityLogonEvents for accounts seen on affected devices
let DeviceIds = AffectedDevices | project DeviceId;
let AccountNames = AffectedUsers | project AccountName;

let IdentityHits = IdentityLogonEvents
| where AccountName in (AccountNames)
| project
    Timestamp,
    AccountName,
    AccountDomain,
    DeviceName,
    LogonType,
    ActionType,
    Application,
    Protocol,
    FailureReason
| extend Source = "IdentityLogonEvents";

// 7. Process activity on affected devices around the time of connection
let NetworkTimestamps = NetworkHits | summarize MinTime = min(Timestamp), MaxTime = max(Timestamp) by DeviceId;

let ProcessHits = DeviceProcessEvents
| where DeviceId in (DeviceIds)
| join kind=inner (NetworkTimestamps) on DeviceId
| where Timestamp between (MinTime .. MaxTime)
| project
    Timestamp,
    DeviceId,
    DeviceName,
    AccountName,
    AccountDomain,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    SHA256
| extend Source = "DeviceProcessEvents";

// ── FINAL CORRELATED OUTPUT ──────────────────────────────────────────────────

// Section A: Raw network connections
NetworkHits
| project-away Source
| extend Section = "A_NetworkConnections"
| union (
    // Section B: Alerts linked to IP
    AlertHits
    | extend
        Section = "B_Alerts",
        InitiatingProcessAccountName = AccountName,
        InitiatingProcessAccountDomain = AccountDomain,
        InitiatingProcessFileName = "",
        InitiatingProcessCommandLine = "",
        LocalIP = "",
        LocalPort = int(null),
        RemotePort = int(null),
        Protocol = "",
        ActionType = EvidenceRole,
        ReportId = long(null)
    | project
        Timestamp,
        DeviceId,
        DeviceName,
        InitiatingProcessAccountName,
        InitiatingProcessAccountDomain,
        InitiatingProcessFileName,
        InitiatingProcessCommandLine,
        LocalIP,
        LocalPort,
        RemoteIP,
        RemotePort,
        Protocol,
        ActionType,
        ReportId,
        Section
)
| union (
    // Section C: Process events on affected devices during connection window
    ProcessHits
    | extend
        Section = "C_ProcessActivity",
        RemoteIP = SuspiciousIP,
        LocalIP = "",
        LocalPort = int(null),
        RemotePort = int(null),
        Protocol = "",
        ActionType = "ProcessCreated",
        ReportId = long(null),
        InitiatingProcessAccountName = AccountName,
        InitiatingProcessAccountDomain = AccountDomain,
        InitiatingProcessFileName = FileName
    | project
        Timestamp,
        DeviceId,
        DeviceName,
        InitiatingProcessAccountName,
        InitiatingProcessAccountDomain,
        InitiatingProcessFileName,
        InitiatingProcessCommandLine = ProcessCommandLine,
        LocalIP,
        LocalPort,
        RemoteIP,
        RemotePort,
        Protocol,
        ActionType,
        ReportId,
        Section
)
| union (
    // Section D: Identity/logon events for involved accounts
    IdentityHits
    | extend
        Section = "D_IdentityLogons",
        DeviceId = "",
        RemoteIP = SuspiciousIP,
        LocalIP = "",
        LocalPort = int(null),
        RemotePort = int(null),
        ReportId = long(null),
        InitiatingProcessFileName = Application,
        InitiatingProcessCommandLine = strcat(LogonType, " | ", FailureReason),
        InitiatingProcessAccountName = AccountName,
        InitiatingProcessAccountDomain = AccountDomain
    | project
        Timestamp,
        DeviceId,
        DeviceName,
        InitiatingProcessAccountName,
        InitiatingProcessAccountDomain,
        InitiatingProcessFileName,
        InitiatingProcessCommandLine,
        LocalIP,
        LocalPort,
        RemoteIP,
        RemotePort,
        Protocol,
        ActionType,
        ReportId,
        Section
)
| sort by Timestamp asc
